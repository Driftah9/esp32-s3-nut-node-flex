# sdkconfig.defaults — persistent overrides for esp32-s3-nut-node
# These settings survive idf.py fullclean, menuconfig resets, and
# sdkconfig regeneration. IDF merges this into sdkconfig at build time.
# Add any setting here that must not revert to IDF defaults.

# ── Flash ────────────────────────────────────────────────────────────────────
# 16MB flash on this board — NEVER let this revert to 2MB
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHFREQ="80m"
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
CONFIG_ESPTOOLPY_FLASHMODE="dio"

# ── Log level ────────────────────────────────────────────────────────────────
# Keep DEBUG log level so HID parser output is visible on monitor
CONFIG_LOG_DEFAULT_LEVEL_DEBUG=y
CONFIG_LOG_DEFAULT_LEVEL=4
